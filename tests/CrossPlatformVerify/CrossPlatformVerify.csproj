<Project Sdk="Microsoft.NET.Sdk">

  <PropertyGroup>
    <OutputType>Exe</OutputType>
    <TargetFramework>net10.0</TargetFramework>
    <Nullable>enable</Nullable>
    <RootNamespace>CrossPlatformVerify</RootNamespace>
  </PropertyGroup>

  <!-- Exclude tests/AssemblyInfo.cs (MSTest) so this console app builds without test framework -->
  <ItemGroup>
    <Compile Remove="$(MSBuildThisFileDirectory)..\AssemblyInfo.cs" />
  </ItemGroup>

  <ItemGroup>
    <ProjectReference Include="..\..\src\Neo\Neo.csproj" />
  </ItemGroup>

</Project>
